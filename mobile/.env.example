# Supabase (same project as the web app)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API base URLs — on a real device these auto-resolve to your dev machine IP.
# Override only if auto-detection fails.
# EXPO_PUBLIC_API_BASE=http://192.168.1.x:8000/api
# EXPO_PUBLIC_NODE_BASE=http://192.168.1.x:3001
