PORT=3001
FRONTEND_URL=http://localhost:3000

# Supabase (auth + DB via @supabase/supabase-js — same project as your app)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Docker image for backend_agent/container (see backend_agent/README.md)
AGENT_IMAGE=ascendfi-backend-agent:latest
CONTAINER_PORT=8080
PORT_RANGE_START=8100
PORT_RANGE_END=8200
INACTIVITY_TIMEOUT_MS=900000

# Passed into each agent container (LM Studio — must be reachable from Docker)
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_MODEL=local-model

# Optional: FastAPI service URL for tools inside the agent (backend_agent/api)
AGENT_BACKEND_URL=http://host.docker.internal:8000

NUXT_PUBLIC_USE_DUMMY_DATA=true
NUXT_PUBLIC_API_BASE=http://localhost:8000/api
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_ANON_KEY=